POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=supportmind
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/supportmind

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=60

APP_NAME=SupportMind
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
ML_USE_TRAINED_MODEL=true
ML_DEVICE=cpu
